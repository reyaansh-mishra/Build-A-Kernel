{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "CMake: Build Preset (LINUX)",
            "command": "reset && CC=clang CXX=clang++ cmake --build build && echo '\n------------------------------------------------------------------------------------------------------------------------------------------------------------\n\n' && qemu-system-i386 -kernel build/kernel.bin",
            "group": "build",
            "problemMatcher": [],
            "detail": "CMake template build task"
        },
        {
            "label": "Clean Rebuild (LINUX)",
            "type": "shell",
            "command": "rm -rf build && CC=clang CXX=clang++ cmake -G \"Unix Makefiles\" -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -S . -B build && cmake --build build && echo '\n------------------------------------------------------------------------------------------------------------------------------------------------------------\n\n' && qemu-system-i386 -kernel build/kernel.bin",
            "group": "build",
            "problemMatcher": []
        },
        // -------------------------------------------------------------------------------------------------------------------------------------------------------------
        {
            "type": "shell",
            "label": "CMake: Build Preset (WINDOWS)",
            "command": "reset && CC=clang CXX=clang++ cmake --preset clang-mingw -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build build && echo '\n------------------------------------------------------------------------------------------------------------------------------------------------------------\n\n' && qemu-system-i386 -kernel build/kernel.bin",
            "group": "build",
            "problemMatcher": [],
            "detail": "CMake template build task"
        },
        {
            "label": "Clean Rebuild (WINDOWS)",
            "type": "shell",
            "command": "rm -rf build && CC=clang CXX=clang++ cmake --preset clang-mingw && cmake --build build && qemu-system-i386 -kernel build/kernel.bin",
            "group": "build",
            "problemMatcher": []
        }
    ]
